{% render 'partials/head.liquid' %}

<main class="log-pg">
    <header class="log-head">
        <a href="/instrumenten/{{ instrument.key }}" class="back">← Terug</a>
        <h1>Beveiligd</h1>
        <p>Voer het wachtwoord in voor <strong>{{ instrument.name }}</strong></p>
    </header>

    <form class="log-form" action="/instrumenten/{{ instrument.key }}/uitlenen" method="POST">
        <div class="veld">
            <label for="pw">Wachtwoord</label>
            <input type="password" name="password" id="pw" required autofocus>
        </div>

        <button type="submit" class="btn-log">Log in</button>
    </form>
</main>

{% render 'partials/foot.liquid' %}