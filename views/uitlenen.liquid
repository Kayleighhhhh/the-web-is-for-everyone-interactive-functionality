{% render 'partials/head.liquid' %}

<main class="uit-pg">
    <header class="uit-head">
        <a href="/instrumenten/{{ instrument.key }}" class="back">← Terug</a>
        <h1>Uitlenen</h1>
        <h2>{{ instrument.name }}</h2>
    </header>

    <form class="uit-form" action="/instrumenten/{{ instrument.key }}/uitlenen" method="POST">
        <img class="uit-img" src="https://fdnd-agency.directus.app/assets/{{ instrument.photo }}" alt="{{ instrument.name }}">
        {% comment %} <img src="assets/DSC_0473.jpg" alt="" class="uit-img"> {% endcomment %}

        <label for="name" class="veld">Wie leent het?</label>
        <input type="text" id="name" name="studentName" placeholder="Volledige naam" required>
        
        <input type="hidden" name="id" value="{{ instrument.id }}">

        <button type="submit" class="btn-uit">Bevestig uitlening</button>
    </form>
</main>

{% render 'partials/foot.liquid' %}